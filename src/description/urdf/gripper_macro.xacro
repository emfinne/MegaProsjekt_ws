<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

    <xacro:macro name="gripper" params="parent prefix *origin">

        <!-- Mount gripper adapter to robot -->
        <joint name="${prefix}gripper_mount_joint" type="fixed">
            <parent link="${parent}"/>
            <child link="${prefix}adapter"/>
            <xacro:insert_block name="origin"/>
        </joint>

        <link name="${prefix}adapter">
            <visual>
                <geometry>
                    <mesh filename="package://description/meshes/gripper/GripperMount.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="aluminum">
                    <color rgba="0.77 0.78 0.80 1.0"/>
                </material>
            </visual>
        </link>

        <!-- Adapter to gripper base -->
        <joint name="${prefix}adapter_to_gripper_base_joint" type="fixed">
            <parent link="${prefix}adapter"/>
            <child link="${prefix}gripper_base"/>
        </joint>

        <link name="${prefix}gripper_base">
            <visual>
                <geometry>
                    <mesh filename="package://description/meshes/gripper/MHL210DBODY.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <origin xyz="0 0 0.031" rpy="0 0 0" />
                <material name="aluminum">
                    <color rgba="0.77 0.78 0.80 1.0"/>
                </material>
            </visual>
        </link>

        <link name="${prefix}left_finger">
            <visual>
                <geometry>
                    <mesh filename="package://description/meshes/gripper/MHL210DFINGER.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <origin xyz="-0.026 0 0.031" rpy="${pi} ${pi} 0" />
                <material name="aluminum">
                    <color rgba="0.77 0.78 0.80 1.0"/>
                </material>
            </visual>
        </link>

        <link name="${prefix}right_finger">
            <visual>
                <geometry>
                    <mesh filename="package://description/meshes/gripper/MHL210DmirrrorFINGER.stl"
                          scale="0.001 0.001 0.001"/>
                </geometry>
                <origin xyz="0.026 0 0.031" rpy="0 0 0" />
                <material name="aluminum">
                    <color rgba="0.77 0.78 0.80 1.0"/>
                </material>
            </visual>
        </link>

        <joint name="${prefix}left_slide" type="prismatic">
            <parent link="${prefix}gripper_base"/>
            <child link="${prefix}left_finger"/>
            <axis xyz="1 0 0"/>
            <limit lower="-0.02" upper="0" effort="50" velocity="0.1"/>
        </joint>

        <joint name="${prefix}right_slide" type="prismatic">
            <parent link="${prefix}gripper_base"/>
            <child link="${prefix}right_finger"/>
            <axis xyz="1 0 0"/>
            <limit lower="0" upper="0.02" effort="50" velocity="0.1"/>
            <mimic joint="${prefix}left_slide" multiplier="-1" offset="0"/>
        </joint>




    </xacro:macro>

</robot>